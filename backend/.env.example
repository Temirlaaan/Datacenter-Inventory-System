# DC Inventory backend — environment variables.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Every variable read by app/config.py is documented here. Adding a new Settings
# field? Add the corresponding line below.

# ---- NetBox (cross-cutting #1: NetBox is the source of truth) ----
# Base URL of the NetBox API. Required.
NETBOX_URL=https://netbox.example.com

# NetBox service-account API token. Required. Treat as a secret.
NETBOX_SERVICE_TOKEN=replace-me

# ---- Keycloak (auth, cross-cutting #6) ----
# Keycloak base URL — the part before /realms/{realm}/. Required.
KEYCLOAK_BASE_URL=https://sso.example.com

# Keycloak realm name. Optional; defaults to prod-v1.
KEYCLOAK_REALM=prod-v1

# How long the JWKS cache is valid before re-fetch. Optional; defaults to 3600.
JWKS_CACHE_TTL_SECONDS=3600

# ---- Database (used by both the app and the entrypoint's `alembic upgrade`) ----
# Postgres credentials are consumed by the dcinv-db service AND assembled into
# DATABASE_URL for dcinv-backend in docker-compose.yml. Keep them in sync.
POSTGRES_DB=dcinv
POSTGRES_USER=dcinv
POSTGRES_PASSWORD=replace-me

# Override only if you're not using the bundled dcinv-db service. Required.
# Must use the +asyncpg driver — SQLAlchemy 2.0 async insists on it.
# DATABASE_URL=postgresql+asyncpg://dcinv:replace-me@dcinv-db:5432/dcinv

# ---- Logging ----
# Optional; defaults to INFO. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# ---- Shift auto-end background job (ToR §4.1.3 fallback) ----
# Toggle the loop. Optional; defaults to true. Set to false in tests / one-off
# tools that should not run the background job.
SHIFT_AUTO_END_ENABLED=true

# Seconds between iterations. Optional; defaults to 300 (5 minutes).
SHIFT_AUTO_END_INTERVAL_SECONDS=300

# Active shifts older than this are auto-ended with end_reason='auto_timeout'.
# Optional; defaults to 12 (matches Sprint 6's 12h fallback decision). The
# 10-minute idle case is mobile-owned — this is the safety net for crashed
# tablets that never sent /sessions/end.
SHIFT_AUTO_END_THRESHOLD_HOURS=12

# ---- NetBox circuit breaker (Architecture §3.3, Sprint 8a Task 2) ----
# Toggle. Optional; defaults to true. Set to false for one-off tools or
# tests that should bypass the circuit entirely.
NETBOX_CIRCUIT_ENABLED=true

# Consecutive NetBoxServerError/NetBoxTimeout failures before circuit opens
# and starts fast-failing as NetBoxCircuitOpenError → HTTP 503. Optional;
# defaults to 5.
NETBOX_CIRCUIT_FAILURE_THRESHOLD=5

# Seconds before the OPEN circuit transitions to HALF_OPEN (one request
# allowed through; success → CLOSED, failure → OPEN again). Surfaced to
# clients as the Retry-After header on 503 responses. Optional; defaults
# to 30.
NETBOX_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=30

# ---- Rate limiting (ToR §5.4.7, Sprint 8a Task 3) ----
# Per-user fixed-window limits enforced as FastAPI middleware. Three
# endpoint classes (READ / WRITE / ADMIN) with separate budgets. Toggle
# for tests / one-off operations. Optional; defaults to true.
RATE_LIMIT_ENABLED=true

# GET / HEAD / OPTIONS on non-/admin/ paths. Optional; defaults to 60.
RATE_LIMIT_READ_PER_MINUTE=60

# POST / PATCH / PUT / DELETE on non-/admin/ paths. Optional; defaults to 20.
RATE_LIMIT_WRITE_PER_MINUTE=20

# Any method under /api/v1/admin/*. Optional; defaults to 30.
RATE_LIMIT_ADMIN_PER_MINUTE=30

# ---- Web admin OIDC (Sprint 8b Task 0) ----
# Confidential Keycloak client used by the /web/* admin pages. Separate
# from the mobile JWT bearer flow (Sprint 1) — register a new client in
# Keycloak with Access Type=confidential + Valid Redirect URI of
# <backend-base>/web/oidc/callback. Optional; defaults to dcinv-web.
KEYCLOAK_WEB_CLIENT_ID=dcinv-web

# Required. The confidential client secret. Treat as a secret; store in
# the secrets directory mount or env-var via your secrets manager.
KEYCLOAK_WEB_CLIENT_SECRET=replace-me

# Required. Fernet key for the dcinv_admin_session encrypted cookie.
# Generate once at deploy and persist (changing this invalidates every
# active web admin session — they'll just have to log in again):
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Treat as a secret.
SESSION_COOKIE_KEY=replace-me

# ---- Secrets directory (Docker swarm/k8s secrets mount) ----
# Optional. Defaults to /run/secrets if that directory exists at boot.
# DCINV_SECRETS_DIR=/run/secrets
